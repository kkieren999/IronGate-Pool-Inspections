rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true
      );
    }

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read: if isOwner(userId) || isAdmin();

      // Owners can update their own profile/settings. They cannot self-approve or grant admin access.
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'approved',
          'role',
          'admin',
          'subscriptionStatus',
          'billingAccess',
          'trialStartedAt',
          'trialEndsAt',
          'currentPeriodEndsAt',
          'stripeCustomerId',
          'stripeSubscriptionId'
        ]);

      // Admins can approve/reject accounts during the Phase 3 workflow.
      allow update: if isAdmin();

      // Temporary client-side account deletion support. Prefer the deleteMyAccount Cloud Function in production.
      allow delete: if isOwner(userId) || isAdmin();

      match /inspections/{inspectionId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }
    }
  }
}
